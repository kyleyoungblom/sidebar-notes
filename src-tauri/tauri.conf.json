{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sidebar Notes",
  "version": "0.6.0",
  "identifier": "com.kyley.sidebar-notes",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Sidebar Notes",
        "url": "index.html",
        "width": 380,
        "height": 800,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": { "allow": ["**"] }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/kyleyoungblom/sidebar-notes/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZEOEU3M0RDOEJGNzYzMQpSV1F4ZHIvSVBlZllEeE94V1FadGxFcXBHTkpjeWFXWGJLUkVHT2luaTNZRm5WMkpjYjR5MEhSaAo="
    }
  }
}
